# Supabase client-safe values
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# App URL used for callbacks, generated links, and production deployment
# Local:
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production example:
# NEXT_PUBLIC_SITE_URL=https://your-vercel-domain.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_EMPLOYER_STARTER_PRICE_ID=
STRIPE_EMPLOYER_PRO_PRICE_ID=
STRIPE_PROVIDER_GROWTH_PRICE_ID=
STRIPE_PROVIDER_PRO_PRICE_ID=

# Never expose service role keys to the browser.
# SUPABASE_SERVICE_ROLE_KEY should only be used in secure server-only scripts if needed.
# Do not prefix private secrets with NEXT_PUBLIC_.
